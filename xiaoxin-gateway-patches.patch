+    # ------------------------------------------------------------------
+    # Text message batching (merge rapid successive messages)
+    # ------------------------------------------------------------------
+
+    def _text_batch_key(self, event: MessageEvent) -> str:
+        """Session-scoped key for text message batching."""
+        from gateway.session import build_session_key
+        return build_session_key(
+            event.source,
+            group_sessions_per_user=True,
+        )
+
+    def _enqueue_text_event(self, event: MessageEvent) -> None:
+        """Buffer a text event and reset the flush timer.
+
+        When a user sends multiple messages in quick succession (common on
+        mobile), this merges them into a single event so the agent replies
+        once instead of to each fragment.
+        """
+        key = self._text_batch_key(event)
+        existing = self._pending_text_batches.get(key)
+        if existing is None:
+            self._pending_text_batches[key] = event
+        else:
+            if event.text:
+                existing.text = f"{existing.text}\n{event.text}" if existing.text else event.text
+            # Keep the latest message_id for dedup
+            if event.message_id:
+                existing.message_id = event.message_id
+
+        prior_task = self._pending_text_batch_tasks.get(key)
+        if prior_task and not prior_task.done():
+            prior_task.cancel()
+        self._pending_text_batch_tasks[key] = asyncio.create_task(
+            self._flush_text_batch(key)
+        )
+
+    async def _flush_text_batch(self, key: str) -> None:
+        """Wait for the quiet period then dispatch the aggregated text.
+
+        If the agent is already busy processing a message for this session,
+        waits until it finishes before dispatching to avoid "Interrupting"
+        messages.
+        """
+        current_task = asyncio.current_task()
+        try:
+            await asyncio.sleep(self._text_batch_delay_seconds)
+
+            # If the agent is busy for this session, wait for it to finish.
+            # _active_sessions contains entries while the agent is processing.
+            wait_count = 0
+            while key in self._active_sessions:
+                wait_count += 1
+                if wait_count == 1:
+                    logger.info(
+                        "[Weixin] Text batch for %s waiting for agent to finish...",
+                        key,
+                    )
+                await asyncio.sleep(0.5)
+                # Cap the wait so we don't block forever (30 seconds max)
+                if wait_count >= 60:
+                    logger.warning(
+                        "[Weixin] Text batch for %s timed out waiting for agent", key
+                    )
+                    break
+
+            event = self._pending_text_batches.pop(key, None)
+            if not event:
+                return
+            logger.info(
+                "[Weixin] Flushing text batch %s (%d chars)",
+                key, len(event.text or ""),
+            )
+            await asyncio.shield(self.handle_message(event))
+        except asyncio.CancelledError:
+            pass
+        finally:
+            if self._pending_text_batch_tasks.get(key) is current_task:
+                self._pending_text_batch_tasks.pop(key, None)
+
+    async def _flush_pending_batch_for_event(self, event: MessageEvent) -> None:
+        """Flush any pending text batch for the same session before dispatching.
+
+        When a media message (image, video, etc.) arrives while a text batch
+        is pending, we flush the batch immediately so the two don't collide
+        and trigger an "Interrupting" message.
+        """
+        key = self._text_batch_key(event)
+        pending = self._pending_text_batches.pop(key, None)
+        if pending:
+            # Cancel the scheduled flush task
+            prior_task = self._pending_text_batch_tasks.pop(key, None)
+            if prior_task and not prior_task.done():
+                prior_task.cancel()
+            logger.info(
+                "[Weixin] Flushing pending text batch for %s before media dispatch (%d chars)",
+                key, len(pending.text or ""),
+            )
+            # Dispatch the batched text first, then the media message will
+            # be dispatched by the caller.  Use shield so the caller's
+            # handle_message can't cancel this dispatch.
+            await asyncio.shield(self.handle_message(pending))
